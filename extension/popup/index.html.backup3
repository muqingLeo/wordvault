<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>WordVault</title>
  <style>
    body {
      width: 380px;
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: transparent;
      overflow: hidden;
    }

    .glass-container {
      position: relative;
      background: rgba(255, 255, 255, 0.075);
      backdrop-filter: blur(48px) saturate(220%);
      -webkit-backdrop-filter: blur(48px) saturate(220%);
      border: 1px solid rgba(255, 255, 255, 0.32);
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 
        0 25px 70px -18px rgba(0, 0, 0, 0.38),
        0 10px 30px -10px rgba(0, 0, 0, 0.22),
        inset 0 1.5px 0 rgba(255, 255, 255, 0.55),
        inset 0 -1px 0 rgba(0, 0, 0, 0.06);
    }

    /* Top light layer */
    .glass-container::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, 
        rgba(255,255,255,0.65) 0%, 
        rgba(255,255,255,0.12) 30%, 
        rgba(255,255,255,0.03) 60%, 
        rgba(200,230,255,0.18) 100%);
      pointer-events: none;
      z-index: 1;
      border-radius: 28px;
    }

    /* Animated liquid glass layer (the moving highlight) */
    .glass-container::after {
      content: '';
      position: absolute;
      top: -70%; left: -70%;
      width: 240%; height: 240%;
      background: radial-gradient(
        circle at var(--mouse-x, 45%) var(--mouse-y, 28%),
        rgba(255,255,255,0.55) 0%,
        rgba(255,255,255,0.22) 22%,
        transparent 55%
      );
      pointer-events: none;
      z-index: 2;
      border-radius: 28px;
      animation: liquid-move 14s ease-in-out infinite;
      mix-blend-mode: screen;
      transition: background-position 0.1s linear;
    }

    @keyframes liquid-move {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      30% { transform: translate(6%, 8%) rotate(2.5deg); }
      60% { transform: translate(-5%, 12%) rotate(-2deg); }
      85% { transform: translate(4%, -4%) rotate(1.5deg); }
    }

    .header {
      margin: 0;
      padding: 20px 24px 16px;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.3px;
      background: linear-gradient(90deg, #007AFF 0%, #00A2FF 100%);
      color: white;
      text-align: center;
      position: relative;
      z-index: 10;
      box-shadow: 0 3px 14px rgba(0, 122, 255, 0.4);
    }

    #content {
      padding: 22px 24px 28px;
      min-height: 380px;
      position: relative;
      z-index: 3;
    }

    .save-btn {
      background: linear-gradient(90deg, #007AFF 0%, #00A2FF 100%);
      color: white;
      border: none;
      padding: 14px 24px;
      font-size: 15px;
      font-weight: 600;
      border-radius: 9999px;
      width: 100%;
      box-shadow: 0 6px 20px rgba(0, 122, 255, 0.45);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .save-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 28px rgba(0, 122, 255, 0.55);
    }
  </style>
</head>
<body>
  <div class="glass-container" id="glass">
    <div class="header">WordVault</div>
    <div id="content"></div>
  </div>
  <script src="popup.js"></script>
</body>
</html>