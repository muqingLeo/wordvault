{
  "manifest_version": 3,
  "name": "WordVault",
  "version": "0.1.0",
  "description": "Personal Highlight-to-Dictionary App",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/index.html"
  }
}
